{
  "manifest_version": 3,
  "name": "CatalogReady Product Agent",
  "version": "0.4.0",
  "description": "Analyze the current product page with a local evidence-grounded CatalogReady agent.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "action": {
    "default_title": "Run product readiness agent",
    "default_popup": "popup.html"
  }
}
